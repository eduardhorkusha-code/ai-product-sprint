# ┌─ .env.local (КОРІНЬ ЗАСТОСУНКУ Expo) ─────────────────────────┐
# │ Скопіюй у .env.local, встав реальні значення.                 │
# │ EXPO_PUBLIC_ = доступно на клієнті. Кладемо СЮДИ лише публічне.│
# └───────────────────────────────────────────────────────────────┘
# Повний гайд по ключах: ../SECRETS.md

# Supabase (supabase.com/dashboard → Settings → API) — публічні, OK у клієнті
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Адреса Vercel AI-proxy (після деплою starter/VERCEL-AI-PROXY.md)
# Застосунок ходить СЮДИ за AI, а не напряму в Anthropic
EXPO_PUBLIC_API_URL=https://твій-проєкт.vercel.app

# ──────────────────────────────────────────────────────────────────
# ⚠️ FALLBACK (тільки якщо немає часу на Vercel proxy — ключ ВИТІКАЄ в bundle)
# Розкоментуй ЛИШЕ для демо і видали/зротуй ключ одразу після:
# EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-api03-...
# EXPO_PUBLIC_OPENAI_API_KEY=sk-proj-...
