# ┌─ Vercel Environment Variables (Project → Settings → Env Vars) ─┐
# │ СЕКРЕТНІ ключі. Живуть ТІЛЬКИ тут, ніколи в клієнті/git.       │
# │ Встав через Vercel UI або: vercel env add ANTHROPIC_API_KEY    │
# └────────────────────────────────────────────────────────────────┘
# Повний гайд: ../SECRETS.md

# 🔴 Must — усі AI-фічі
ANTHROPIC_API_KEY=sk-ant-api03-...

# Модель за замовчуванням для proxy.
# claude-opus-4-8     = найрозумніша (для "wow" фічі)
# claude-haiku-4-5    = найшвидша/дешева (для live-демо, миттєвий відгук)
CLAUDE_MODEL=claude-opus-4-8

# 🟢 Voice→text (Whisper) — якщо робите голос
OPENAI_API_KEY=sk-proj-...

# ⚪ TTS (AI-голос на виході) — опційно
ELEVENLABS_API_KEY=sk_...

# 🗄️ Тільки якщо proxy пише в Supabase bypass RLS (на демо зазвичай не треба)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
